{
  "name": "initial-baseball",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo build",
    "build:web": "pnpm --filter @initial-baseball/shared build && pnpm --filter @initial-baseball/engine build && pnpm --filter @initial-baseball/baseball-data build && pnpm --filter @initial-baseball/daily build && pnpm --filter @initial-baseball/web build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "check:file-sizes": "node scripts/check-file-sizes.mjs",
    "data:audit": "pnpm --filter @initial-baseball/baseball-data audit:current",
    "data:identities": "pnpm --filter @initial-baseball/baseball-data generate:canonical-identities",
    "data:universe": "pnpm data:identities && pnpm --filter @initial-baseball/baseball-data generate:canonical-universe"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "next": "^15.1.0",
    "pnpm": "9.15.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  }
}
