# Mobile client public env
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_APP_ENV=development

# Server-only Supabase/editorial administration configuration.
# Never prefix these variables with NEXT_PUBLIC_* or expose them to browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DAILY_ADMIN_USERNAME=
# Use at least 32 random characters. HTTP Basic authentication is allowed only over HTTPS.
DAILY_ADMIN_PASSWORD=

# Required for Preview and Production Daily progression tokens.
# Use at least 32 random characters and never expose this as NEXT_PUBLIC_*.
DAILY_PROGRESSION_SECRET=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_DAILY_BASE_URL=http://localhost:3000
