{
  "name": "@initial-baseball/baseball-data",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "cd ../.. && node scripts/generate-season-stats.mjs && cd packages/baseball-data && tsc -p tsconfig.json",
    "generate:players": "node ./scripts/generate-players.mjs",
    "generate:seasons": "cd ../.. && node scripts/generate-season-stats.mjs",
    "generate:canonical-identities": "node ./scripts/generate-canonical-identities.mjs && node ./scripts/generate-identity-review-evidence.mjs && node ./scripts/recommend-identity-dispositions.mjs",
    "generate:canonical-identities:strict": "node ./scripts/generate-canonical-identities.mjs --strict && node ./scripts/generate-identity-review-evidence.mjs && node ./scripts/recommend-identity-dispositions.mjs",
    "generate:canonical-universe": "node ./scripts/generate-canonical-universe.mjs",
    "generate:canonical-universe:strict": "node ./scripts/generate-canonical-universe.mjs --strict",
    "generate:canonical-season-facts": "node ./scripts/generate-canonical-season-facts.mjs",
    "generate:canonical-season-facts:strict": "node ./scripts/generate-canonical-season-facts.mjs --strict",
    "generate:canonical-season-aggregates": "node ./scripts/generate-canonical-season-aggregates.mjs",
    "generate:canonical-season-aggregates:strict": "node ./scripts/generate-canonical-season-aggregates.mjs --strict",
    "generate:canonical-season-cards": "node ./scripts/generate-canonical-season-cards.mjs",
    "generate:canonical-season-cards:strict": "node ./scripts/generate-canonical-season-cards.mjs --strict",
    "qa:canonical-season-cards": "node ./scripts/qa-canonical-season-cards.mjs",
    "audit:current": "node ./scripts/audit-current-data.mjs",
    "audit:current:strict": "node ./scripts/audit-current-data.mjs --strict",
    "pretest": "pnpm --filter @initial-baseball/shared build && pnpm build",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@initial-baseball/shared": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
